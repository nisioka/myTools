#!/bin/bash
# ws - Workspace Manager
#
# IDEのターミナルで ws add → tmuxセッション開始（セッション名=ディレクトリ名）
# 別モニターで ws dash → 全セッションをミラーして一覧表示
#
# コマンド:
#   ws add [-g group] [name]         - tmuxセッションを作成しattach（-gでグループ付与）
#   ws rm [name]                     - セッションを終了（名前省略=ディレクトリ名）
#   ws list [-g group] [-G group]    - 一覧表示（-g: 絞り込み、-G: 除外）
#   ws dash [-g group] [-G group]    - ダッシュボードを開く（-g: 絞り込み、-G: 除外）
#   ws help                          - ヘルプ

WS_PREFIX="ws-"
WS_GROUP_FILE="$HOME/.config/ws/groups"

_session_name() {
    local name="${1//\./_}"
    name="${name//:/_}"
    echo "${WS_PREFIX}${name}"
}

_list_ws() {
    tmux list-sessions -F '#S' 2>/dev/null | grep "^${WS_PREFIX}" | sed "s/^${WS_PREFIX}//"
}

_ensure_group_file() {
    [ -f "$WS_GROUP_FILE" ] || { mkdir -p "$(dirname "$WS_GROUP_FILE")"; touch "$WS_GROUP_FILE"; }
}

_set_group() {
    local name="$1" group="$2"
    _ensure_group_file
    _remove_group "$name"
    printf '%s\t%s\n' "$name" "$group" >> "$WS_GROUP_FILE"
}

_get_group() {
    [ -f "$WS_GROUP_FILE" ] || return
    awk -F'\t' -v n="$1" '$1==n{print $2; exit}' "$WS_GROUP_FILE"
}

_remove_group() {
    [ -f "$WS_GROUP_FILE" ] || return
    local tmp
    tmp=$(awk -F'\t' -v n="$1" '$1!=n' "$WS_GROUP_FILE")
    printf '%s\n' "$tmp" > "$WS_GROUP_FILE"
}

_list_ws_filtered() {
    local include="$1" exclude="$2"
    local sessions
    sessions=$(_list_ws)
    [ -z "$sessions" ] && return

    while read -r name; do
        local grp
        grp=$(_get_group "$name")
        if [ -n "$include" ] && [ "$grp" != "$include" ]; then
            continue
        fi
        if [ -n "$exclude" ] && [ "$grp" = "$exclude" ]; then
            continue
        fi
        echo "$name"
    done <<< "$sessions"
}

_build_panes() {
    # 新しいウィンドウにペインを構築する共通処理
    # 引数: "new" (新規セッション作成) または "window" (既存セッションに新ウィンドウ追加)
    local mode="$1"
    shift
    local sessions="$1"

    local first=true
    while read -r name; do
        local sess="$(_session_name "$name")"
        if $first; then
            if [ "$mode" = "new" ]; then
                tmux -L ws-dash new-session -d -s dash \
                    "unset TMUX; tmux attach -t '=$sess'"
            else
                tmux -L ws-dash new-window -t dash \
                    "unset TMUX; tmux attach -t '=$sess'"
            fi
            tmux -L ws-dash select-pane -T "$name"
            first=false
        else
            tmux -L ws-dash split-window -t dash \
                "unset TMUX; tmux attach -t '=$sess'"
            tmux -L ws-dash select-pane -T "$name"
            tmux -L ws-dash select-layout -t dash tiled
        fi
    done <<< "$sessions"

    # ペイン数に応じてレイアウト選択（横並び優先）
    local pane_count
    pane_count=$(tmux -L ws-dash list-panes -t dash 2>/dev/null | wc -l)
    if [ "$pane_count" -le 3 ]; then
        tmux -L ws-dash select-layout -t dash even-horizontal
    else
        tmux -L ws-dash select-layout -t dash tiled
    fi
    tmux -L ws-dash set-option -t dash pane-border-status top 2>/dev/null
    tmux -L ws-dash set-option -t dash pane-border-format ' #T ' 2>/dev/null
}

_rebuild_dash() {
    local include="$1" exclude="$2"
    local sessions
    sessions=$(_list_ws_filtered "$include" "$exclude")
    local count=0
    [ -n "$sessions" ] && count=$(echo "$sessions" | wc -l)

    if [ "$count" -eq 0 ]; then
        tmux -L ws-dash kill-session -t dash 2>/dev/null
        echo "ワークスペースがありません"
        return 1
    fi

    if tmux -L ws-dash has-session -t dash 2>/dev/null; then
        # ダッシュボードが開いている場合: 新ウィンドウを作って古いのを消す
        local old_windows
        old_windows=$(tmux -L ws-dash list-windows -t dash -F '#{window_id}')

        _build_panes window "$sessions"

        # 古いウィンドウを削除（クライアントは新ウィンドウに自動切替済み）
        for wid in $old_windows; do
            tmux -L ws-dash kill-window -t "$wid" 2>/dev/null
        done
    else
        # ダッシュボードが無い場合: 新規作成
        _build_panes new "$sessions"
    fi
}

cmd_add() {
    local group=""
    local OPTIND=1
    while getopts "g:" opt; do
        case "$opt" in
            g) group="$OPTARG" ;;
            *) cmd_help; return 1 ;;
        esac
    done
    shift $((OPTIND - 1))

    local name="${1:-$(basename "$PWD")}"
    local sess="$(_session_name "$name")"

    if tmux has-session -t "=$sess" 2>/dev/null; then
        if [ -n "$group" ]; then
            _set_group "$name" "$group"
            echo "✓ '$name' のグループを '$group' に設定しました"
        fi
        echo "⚠ '$name' は既に存在します。attachします"
        exec tmux attach -t "=$sess"
    fi

    tmux new-session -d -s "$sess"

    if [ -n "$group" ]; then
        _set_group "$name" "$group"
    fi

    if tmux -L ws-dash has-session -t dash 2>/dev/null; then
        _rebuild_dash
        echo "ダッシュボードを更新しました"
    fi

    exec tmux attach -t "=$sess"
}

cmd_rm() {
    local name="${1:-$(basename "$PWD")}"
    local sess="$(_session_name "$name")"

    if ! tmux has-session -t "=$sess" 2>/dev/null; then
        echo "⚠ '$name' は存在しません"
        return 1
    fi

    local dash_updated=false

    # dashが存在する場合、対応するペインを先に削除してレイアウト再適用
    if tmux -L ws-dash has-session -t dash 2>/dev/null; then
        local pane_id
        pane_id=$(tmux -L ws-dash list-panes -t dash -F '#{pane_id} #{pane_title}' 2>/dev/null \
            | while read -r id title; do
                if [ "$title" = "$name" ]; then
                    echo "$id"
                    break
                fi
            done)
        if [ -n "$pane_id" ]; then
            tmux -L ws-dash kill-pane -t "$pane_id" 2>/dev/null
        fi

        # dashセッションがまだ存在するならペイン数に応じてレイアウト再適用
        if tmux -L ws-dash has-session -t dash 2>/dev/null; then
            local pane_count
            pane_count=$(tmux -L ws-dash list-panes -t dash 2>/dev/null | wc -l)
            if [ "$pane_count" -le 3 ]; then
                tmux -L ws-dash select-layout -t dash even-horizontal
            else
                tmux -L ws-dash select-layout -t dash tiled
            fi
            dash_updated=true
        fi
    fi

    tmux kill-session -t "=$sess"
    _remove_group "$name"
    echo "✓ '$name' を終了しました"

    if $dash_updated; then
        echo "  ダッシュボードを更新しました"
    fi
}

cmd_list() {
    local include="" exclude=""
    local OPTIND=1
    while getopts "g:G:" opt; do
        case "$opt" in
            g) include="$OPTARG" ;;
            G) exclude="$OPTARG" ;;
            *) cmd_help; return 1 ;;
        esac
    done
    shift $((OPTIND - 1))

    local sessions
    sessions=$(_list_ws_filtered "$include" "$exclude")
    if [ -z "$sessions" ]; then
        echo "アクティブなワークスペースはありません"
        return
    fi
    echo "ワークスペース:"
    while read -r name; do
        local sess="$(_session_name "$name")"
        local dir grp
        dir=$(tmux display-message -t "=$sess" -p '#{pane_current_path}' 2>/dev/null)
        grp=$(_get_group "$name")
        if [ -n "$grp" ]; then
            echo "  $name  [$grp]  ($dir)"
        else
            echo "  $name  ($dir)"
        fi
    done <<< "$sessions"
}

cmd_dash() {
    local include="" exclude=""
    local OPTIND=1
    while getopts "g:G:" opt; do
        case "$opt" in
            g) include="$OPTARG" ;;
            G) exclude="$OPTARG" ;;
            *) cmd_help; return 1 ;;
        esac
    done
    shift $((OPTIND - 1))

    _rebuild_dash "$include" "$exclude" || return
    exec tmux -L ws-dash attach -t dash
}

cmd_help() {
    cat << 'EOF'
ws - Workspace Manager

コマンド:
  ws add [-g group] [name]   tmuxセッションを作成してattach（名前省略=ディレクトリ名）
  ws rm [name]               セッションを終了（名前省略=ディレクトリ名）
  ws list [-g group] [-G group]  一覧表示
  ws dash [-g group] [-G group]  ミラーダッシュボードを開く
  ws help                    このヘルプ

グループオプション:
  -g group   グループ名を指定（addでは付与、list/dashでは絞り込み）
  -G group   指定グループを除外（list/dashで使用）

使い方:
  # 各IDEのターミナルで
  cd ~/projects/api && ws add -g backend    # → "ws-api" をbackendグループで作成
  cd ~/projects/web && ws add -g frontend   # → "ws-web" をfrontendグループで作成
  cd ~/projects/db && ws add                # → "ws-db" をグループなしで作成

  # グループで絞り込み
  ws list -g backend              # → backendグループのみ表示
  ws list -G frontend             # → frontendグループを除外して表示
  ws dash -g backend              # → backendグループのみダッシュボード表示

  # 別モニター / 別ターミナルで
  ws dash                           # → 全セッションがタイル表示でミラー

  # 既存セッションにグループを後付け
  ws add -g backend api             # → 既存の"api"にbackendグループを設定

ダッシュボード操作:
  Ctrl+B → 矢印   ペイン間移動（入力もできる）
  Ctrl+B → D       ダッシュボードから抜ける

セッション増減時:
  ws add / ws rm 後、ダッシュボードは自動更新
  手動更新は別ターミナルで ws dash を再実行
EOF
}

case "${1:-help}" in
    add)  shift; cmd_add "$@" ;;
    rm)   shift; cmd_rm "$@" ;;
    list) shift; cmd_list "$@" ;;
    dash) shift; cmd_dash "$@" ;;
    help|--help|-h) cmd_help ;;
    *)    echo "不明なコマンド: $1"; cmd_help; exit 1 ;;
esac
